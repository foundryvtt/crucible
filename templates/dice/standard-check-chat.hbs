<div class="{{cssClass}} line-item" data-action="expandRoll">
    {{#if actor}}
    <img class="icon" src="{{actor.img}}" alt="{{actor.name}}">
    <div class="title">
        <h4 class="ellipsis" data-tooltip="{{actor.name}}">{{actor.name}}</h4>
    </div>
    {{/if}}
    {{#if data.newTarget}}
    <div class="roll-target flexrow">
        <label class="tag-icon">
        <i class="fa-solid fa-bullseye"></i>
        </label>
        <div class="tags" data-tag-type="target">
            <span class="target-link tag" data-uuid="{{target.uuid}}">{{target.name}}</span>
        </div>
    </div>
    {{/if}}
    {{> "systems/crucible/templates/dice/partials/standard-check-dice-result.hbs"}}
</div>
