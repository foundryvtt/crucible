<header class="action-header">
    <img class="icon" src="{{action.img}}" alt="{{action.name}}">
    <div class="title">
        <h4>{{action.name}}</h4>
        {{crucibleTags tags.activation tagType="activation"}}
    </div>
</header>

{{#if hasActionTags}}
<div class="action-tags full-tags">
    <label class="tag-icon" data-tooltip="Action Tags" data-tooltip-direction="LEFT">
        <i class="fa-solid fa-bolt"></i>
    </label>
    {{crucibleTags tags.action tagType="action"}}
</div>
{{/if}}

{{#if hasContextTags}}
<div class="context-tags full-tags">
    <label class="tag-icon" data-tooltip="{{tags.context.label}}" data-tooltip-direction="LEFT">
        <i class="{{tags.context.icon}}"></i>
    </label>
    {{crucibleTags tags.context tagType="context"}}
</div>
{{/if}}

{{#if hasTargets}}
<div class="target-template full-tags">
    <label class="tag-icon" data-tooltip="{{localize "ACTION.Targets"}}" data-tooltip-direction="LEFT">
        <i class="fa-solid fa-bullseye"></i>
    </label>
    <div class="tags" data-tag-type="target">
        {{#if requiresRegion}}
        <button class="place-region frame-brown" type="button" data-action="placeRegion">
            <i class="fa-solid fa-ruler-combined"></i>
            {{localize "ACTION.PlaceRegion"}}
        </button>
        {{else}}
        {{#each targets}}
        {{#unless hidden}}
        <span class="target-link tag {{this.cssClass}}" data-uuid="{{this.uuid}}"
              {{#if this.tooltip}}data-tooltip="{{this.tooltip}}"{{/if}}>{{this.name}}</span>
        {{/unless}}
        {{else}}
        <span class="tag unmet">{{localize "ACTION.NoTargets"}}</span>
        {{/each}}
        {{/if}}
    </div>
</div>
{{/if}}

<div class="description">
    {{#if action.condition}}
    <p class="condition"><strong>{{localize "ACTION.Condition"}}:</strong> {{{action.condition}}}</p>
    {{/if}}
    {{{action.description}}}
</div>

