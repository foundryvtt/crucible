<header class="sheet-header flexrow">
    <img class="profile" src="{{source.img}}" alt="{{source.name}}" data-action="editImage" data-edit="img">
    <div class="name flexcol">
        <h1 class="title">
            {{formInput fields.name value=source.name placeholder=(localize "EFFECT.FIELDS.name.label")}}
        </h1>
        <div class="metadata flexrow">
            {{~crucibleTags tags additionalClasses="header-tags"~}}
        </div>
    </div>
</header>
